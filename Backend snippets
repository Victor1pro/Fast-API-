from sqlalchemy.orm import Session
from app.models.user_model import User
from app.utils.hashing import PasswordHasher
from app.utils.jwt_handler import create_access_token, create_refresh_token
from app.service.cart_service import merge_guest_cart
from fastapi import HTTPException, status, Response


def register_user_service(payload, db: Session):
    existing_user = db.query(User).filter(User.email == payload.email).first()
    if existing_user:
        raise HTTPException(
            status_code = status.HTTP_400_BAD_REQUEST,
            detail="Email already registered"
        )

    new_user = User(
        name=payload.name,
        email=payload.email,
        hashed_password=PasswordHasher.hash_password(payload.password)
    )

    db.add(new_user)
    db.commit()
    db.refresh(new_user)

    return new_user


def login_user_service(payload, db: Session, response: Response, guest_token: str | None):
    user = db.query(User).filter(User.email == payload.email).first()

    if not user or not PasswordHasher.verify_password(payload.password, user.hashed_password):
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Invalid email or password"
        )

    # -------------------------
    # MERGE GUEST CART → USER CART
    # -------------------------
    if guest_token:
        merge_guest_cart(db, user.id, guest_token)

    # -------------------------
    # DELETE GUEST COOKIE
    # -------------------------
    response.delete_cookie(
        key="guest_token",
        path="/",
        httponly=True,
        samesite="lax",
        secure=False
    )

    # -------------------------
    # CREATE TOKENS
    # -------------------------
    access_token = create_access_token(str(user.id))
    refresh_token = create_refresh_token(str(user.id))

    # -------------------------
    # SET ACCESS TOKEN COOKIE
    # -------------------------
    response.set_cookie(
        key="access_token",
        value=access_token,
        httponly=True,
        secure=False,
        samesite="lax",
        max_age=60 * 15
    )

    # -------------------------
    # SET REFRESH TOKEN COOKIE
    # -------------------------
    response.set_cookie(
        key="refresh_token",
        value=refresh_token,
        httponly=True,
        secure=True,
        samesite="lax",
        max_age=60 * 60 * 24 * 7
    )

    return {
        "message": "Login Successful",
        "access_token": access_token,
        "token_type": "bearer"
    }


# ------------------------
# LOGOUT SERVICE
# ------------------------
def logout_user_service(response: Response):

    # ACCESS TOKEN COOKIE
    response.delete_cookie(
        key = "access_token",
        httponly = True,
        secure = False,
        samesite = "strict"
    )


    # REFRESH TOKEN COOKIE
    response.delete_cookie(
        key = "refresh_token",
        httponly = True,
        secure = False,
        samesite = "strict"
    )

    return {"message": "Logged out successfully"}

