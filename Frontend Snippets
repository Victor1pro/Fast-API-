# CSS Styles
:root {
  /* ===== Brand Colors ===== */
  --color-primary: #2F6B3F;
  --color-primary-600: #285C36;
  --color-primary-700: #214D2D;

  --color-primary-light: #8A9A5B;
  --color-primary-light-600: #7A8A50;

  /* ===== Accent Colors ===== */
  --color-accent-yellow: #F2C94C;
  --color-accent-orange: #FF9F1C;
  --color-accent-orange-600: #E88E18;
  --color-accent-terra: #C46D3B;

  --color-accent-orange: #FF9F1C;       /* base */
  --color-accent-orange-600: #E88E18;   /* hover */
  --color-accent-orange-700: #C77712;   /* active */
  --color-accent-orange-800: #9F5F0E;   /* TEXT SAFE */

  /* ===== Supporting ===== */
  --color-secondary-soft: #A3B18A;

  /* ===== Neutral ===== */
  --color-bg: #E5E2D5;
  --color-surface: #FFFFFF;

  --color-text: #2E2E2E;
  --color-text-muted: #6B6B6B;

  --color-border: #D6D2C4;
  --color-border-strong: #BFBBAA;

  /* ===== States ===== */
  --color-success: #4CAF50;
  --color-warning: #F2C94C;
  --color-error: #D64545;

  /* ===== Typography ===== */
  --font-main: 'Inter', sans-serif;
  --font-heading: 'Poppins', sans-serif;

  --text-xs: 0.75rem;
  --text-sm: 0.875rem;
  --text-base: 1rem;
  --text-lg: 1.25rem;
  --text-xl: 1.5rem;
  --text-2xl: 2rem;

  /* Line Heights (THIS is key for readability) */
  --line-tight: 1.2;   /* headings */
  --line-normal: 1.5;  /* body */
  --line-loose: 1.7;   /* long text */

  /* Font Weights */
  --weight-regular: 400;
  --weight-medium: 500;
  --weight-bold: 700;

  /* ===== Spacing ===== */
  --space-xs: 4px;
  --space-sm: 8px;
  --space-md: 16px;
  --space-lg: 24px;
  --space-xl: 32px;

  /* ===== Borders & Radius ===== */
  --border-thin: 1px;
  --border-thick: 2px;

  --radius-sm: 6px;
  --radius-md: 8px;
  --radius-lg: 12px;

  /* ===== Shadows ===== */
  --shadow-soft: 0 2px 6px rgba(0,0,0,0.08);
  --shadow-medium: 0 4px 12px rgba(0,0,0,0.12);

  /* ===== Transitions ===== */
  --transition-fast: 0.2s ease;
  --transition-smooth: 0.3s ease;
}


