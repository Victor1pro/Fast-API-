# CSS SNippets
/* Layout */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 20px;
  background: #131921; /* Amazon dark blue */
  color: white;
}

/* Logo + text */
.logo-area {
  display: flex;
  align-items: center;
  gap: 8px;
}

.logo {
  width: 40px;
  height: auto;
}

.brand-text {
  font-size: 1.2rem;
  font-weight: 600;
}

/* Search bar */
.search-area {
  display: flex;
  flex: 1;
  max-width: 600px;
  margin: 0 20px;
}

.search-input {
  flex: 1;
  padding: 10px;
  border: none;
  border-radius: 4px 0 0 4px;
  font-size: 1rem;
}

.search-btn {
  padding: 10px 16px;
  background: #febd69; /* Amazon yellow */
  border: none;
  border-radius: 0 4px 4px 0;
  cursor: pointer;
  font-weight: bold;
}

/* Menu links */
.menu {
  display: flex;
  gap: 20px;
}

.menu-link {
  position: relative;
  color: white;
  text-decoration: none;
  font-size: 1rem;
}

/* Animated underline */
.menu-link::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -3px;
  width: 0%;
  height: 2px;
  background: #febd69;
  transition: width 0.3s ease;
}

.menu-link:hover::after {
  width: 100%;
}

/* Responsive */
@media (max-width: 768px) {
  .header {
    flex-wrap: wrap;
    gap: 12px;
  }

  .search-area {
    order: 3;
    width: 100%;
    margin: 0;
  }

  .menu {
    order: 2;
    width: 100%;
    justify-content: center;
  }
}
