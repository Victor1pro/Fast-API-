/* ===== LOGO ===== */
.header-left {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.logo {
  width: 42px;
}

.brand-text {
  font-family: var(--font-heading);
  font-size: var(--text-lg);
  font-weight: var(--weight-bold);
}

/* ===== SEARCH BAR ===== */
.header-center {
  flex: 1;
  max-width: 600px;
  display: flex;
  margin: 0 var(--space-md);
}

.search-input {
  flex: 1;
  padding: var(--space-sm) var(--space-md);
  border: var(--border-thin) solid var(--color-border);
  border-right: none;
  border-radius: var(--radius-md) 0 0 var(--radius-md);
}

.search-btn {
  padding: var(--space-sm) var(--space-lg);
  background: var(--color-accent-orange);
  border: none;
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
  color: white;
  cursor: pointer;
  transition: var(--transition-fast);
}

.search-btn:hover {
  background: var(--color-accent-orange-600);
}

/* ===== DESKTOP NAV ===== */
.header-right .nav-list {
  display: flex;
  gap: var(--space-lg);
  list-style: none;
}

.nav-list a {
  color: white;
  text-decoration: none;
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  transition: var(--transition-fast);
}

.nav-list a:hover {
  background: var(--color-primary-600);
}

/* ===== HAMBURGER ===== */
.hamburger {
  display: none;
  background: none;
  border: none;
  color: white;
  font-size: var(--text-xl);
  cursor: pointer;
}

/* ===== BACKDROP ===== */
.backdrop {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--transition-smooth);
}

.backdrop.show {
  opacity: 1;
  pointer-events: auto;
}

/* ===== SLIDE-IN DRAWER ===== */
.mobile-drawer {
  position: fixed;
  top: 0;
  left: 0;
  width: 260px;
  height: 100vh;
  background: var(--color-primary-700);
  color: white;
  padding: var(--space-md);
  transform: translateX(-100%);
  transition: transform var(--transition-smooth);
  display: flex;
  flex-direction: column;
  gap: var(--space-lg);
  z-index: 999;
}

.mobile-drawer.open {
  transform: translateX(0);
}

.drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.drawer-title {
  font-size: var(--text-xl);
  font-weight: var(--weight-bold);
}

.close-btn {
  background: none;
  border: none;
  color: white;
  font-size: var(--text-xl);
  cursor: pointer;
}

.drawer-links {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.drawer-links a {
  color: white;
  text-decoration: none;
  font-size: var(--text-lg);
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-sm);
  border-radius: var(--radius-sm);
  transition: var(--transition-fast);
}

.drawer-links a:hover {
  background: var(--color-primary-600);
}

/* ===== RESPONSIVE ===== */
@media (max-width: 900px) {
  .header-right {
    display: none;
  }

  .hamburger {
    display: block;
  }

  .header-center {
    order: 3;
    width: 100%;
    margin-top: var(--space-sm);
  }
}

@media (max-width: 600px) {
  .brand-text {
    display: none;
  }
}


